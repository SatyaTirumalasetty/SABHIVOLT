# ── Frontend (exposed to browser — safe: anon key is public by design) ──
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Serverless only (set in Vercel dashboard, NEVER commit real values) ──
# Required for enquiry email notifications. The /api/notify function verifies
# each enquiry against the database using the service-role key before emailing,
# so all four of these must be set for notifications to fire.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxxxxxxx
NOTIFY_EMAIL=hello@sabhivolt.com

# Optional: sender shown on the notification email (verify the domain in Resend first).
NOTIFY_FROM=SABHIVOLT Website <onboarding@resend.dev>
# Optional: comma-separated origin allowlist for /api/notify (e.g. https://sabhivolt.com).
ALLOWED_ORIGIN=
